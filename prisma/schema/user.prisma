model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String
  role            Role     @default(USER)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tickets         Ticket[]
  assignedTickets Ticket[] @relation("AssignedTickets")

  comments Comment[]
}

enum Role {
  USER
  SUPPORT
  ADMIN
}
